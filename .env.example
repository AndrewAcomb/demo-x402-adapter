# Base network to accept payments on.
#   eip155:84532 = Base Sepolia (testnet — use for demo, no real money)
#   eip155:8453  = Base mainnet (real USDC)
X402_NETWORK=eip155:84532

# Where settled USDC lands. Any EVM address you control.
X402_PAY_TO=0x0000000000000000000000000000000000000000

# Facilitator that verifies + settles payments on your behalf.
#   Testnet:  https://x402.org/facilitator
#   Mainnet:  https://api.cdp.coinbase.com/platform/v2/x402/facilitator
X402_FACILITATOR_URL=https://x402.org/facilitator

# Server port
PORT=3000

# Coinbase CDP API key (portal.cdp.coinbase.com). Required for mainnet:
# when both are set, the CDP facilitator is used and X402_FACILITATOR_URL
# is ignored. Leave unset for the public testnet facilitator.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Optional fallback challenge price if a product cannot be resolved (default $0.10).
# X402_PRICE=$0.10

# Optional: override the Merchant Factory onboarding price (default $5.00).
# X402_ONBOARDING_PRICE=$5.00

# Upstash-compatible Redis REST store. Required for durable orders, live
# progress events, and dynamic catalogs. The UPSTASH_REDIS_REST_* names are
# accepted as aliases.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional key for the undocumented, unpaid POST /admin/merchants operator
# route. Public POST /merchants remains x402-paid and does not use this key.
ONBOARD_ADMIN_KEY=

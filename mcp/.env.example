# x402 Shopper — configuration. Copy to .env and edit. NEVER commit .env.

# ---- Wallet (buyer) -------------------------------------------------------
# The local signing key used to pay x402 challenges. It NEVER leaves this
# machine and is never returned by any tool. Leave unset and use MOCK_PAY=1 to
# run without a key.
# X402_BUYER_PRIVATE_KEY=0x<64-hex-chars>

# EVM network (CAIP-2). Default is Base Sepolia testnet.
X402_NETWORK=eip155:84532

# ---- Safety caps ----------------------------------------------------------
# Per-purchase ceiling (USD). A single buy above this is refused / stays dry-run.
MAX_SPEND_USD=50
# Cumulative per-process budget (USD). Held in memory; resets on restart.
SESSION_BUDGET_USD=100
# Master switch for real spend. buy() only settles when this is 1 AND confirm=true.
ALLOW_REAL_PURCHASE=0

# ---- Merchants ------------------------------------------------------------
# Comma-separated merchant base URLs for discover_merchants / list_products.
MERCHANT_URLS=https://buywith402.com

# ---- Mock modes (offline demo & tests) ------------------------------------
# Serve an in-process fake merchant (catalog, 402 challenge, fulfillment stream).
# MOCK_MERCHANT=1
# Skip real signing/settlement and pretend payment succeeded.
# MOCK_PAY=1

{
  "name": "x402-shopper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "x402 Shopper — a local stdio MCP server that gives any MCP agent a USDC wallet to discover x402 merchants, comparison-shop, and buy physical goods. Dry-run by default; streams live fulfillment + checkout screenshots over MCP progress notifications.",
  "bin": {
    "x402-shopper": "src/server.ts"
  },
  "scripts": {
    "start": "tsx src/server.ts",
    "demo": "MOCK_MERCHANT=1 MOCK_PAY=1 node scripts/smoke.mjs",
    "smoke": "node scripts/smoke.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "@x402/core": "^2.18.0",
    "@x402/evm": "^2.18.0",
    "@x402/extensions": "^2.18.0",
    "@x402/fetch": "^2.18.0",
    "viem": "^2.55.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}

#!/usr/bin/env python
"""Operator CLI for the H browser fulfillment demo."""

from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path

from add_cached_to_cart import AddressBook, describe_catalog, newest_catalog
from email_2fa import ImapCodeReader


ROOT = Path(__file__).resolve().parent
RUNTIME = ROOT / "runtime"
RUNTIME_SUBDIRECTORIES = ("catalogs", "sessions", "logs", "private", "legacy")


HELP = """Usage:
  ./h402 doctor [--online]
  ./h402 catalog refresh
  ./h402 catalog list
  ./h402 cart reset
  ./h402 cart [reset|noreset] add <product-id|-i> [checkout <address-id|-i>]
      [--place-order] [--resume]
  ./h402 checkout <address-id|-i> [--place-order] [--resume]
  ./h402 profile open|publish
  ./h402 logs [--local]

Global browser options:
  --proxy true|false          Use the configured proxy (default: true)
  --h-environment env1        Configured H environment (default: profile state)

Examples:
  ./h402 cart add -i
  ./h402 cart add mcmaster:92224A112
  ./h402 checkout -i
  ./h402 cart reset add -i checkout -i
  ./h402 cart reset add 92224A112 checkout 1
  ./h402 cart noreset add 92224A112 checkout 1
  ./h402 cart add 92224A112 checkout 1 --place-order
  ./h402 cart noreset add 92224A112 --resume

Adding resets the cart by default. Include `noreset` to opt out.
"""


def fail(message: str) -> None:
    raise SystemExit(f"h402: {message}\n\n{HELP}")


def run_script(name: str, arguments: list[str]) -> None:
    completed = subprocess.run(
        [sys.executable, str(ROOT / name), *arguments], cwd=ROOT
    )
    raise SystemExit(completed.returncode)


def ensure_runtime_layout() -> None:
    for name in RUNTIME_SUBDIRECTORIES:
        (RUNTIME / name).mkdir(parents=True, exist_ok=True)


def selector_argument(
    value: str, interactive_flag: str, value_flag: str
) -> list[str]:
    return [interactive_flag] if value == "-i" else [value_flag, value]


def extract_browser_options(tokens: list[str]) -> tuple[list[str], list[str]]:
    """Extract position-independent browser options into canonical argv form."""
    cleaned: list[str] = []
    extracted: dict[str, str] = {}
    index = 0
    while index < len(tokens):
        token = tokens[index]
        if token in {"--proxy", "--h-environment", "--environment"}:
            canonical = "--h-environment" if token != "--proxy" else token
            if canonical in extracted:
                fail(f"{canonical} may be specified only once")
            if index + 1 >= len(tokens):
                fail(f"{token} requires a value")
            value = tokens[index + 1]
            if canonical == "--proxy" and value not in {"true", "false"}:
                fail("--proxy must be true or false")
            extracted[canonical] = value
            index += 2
        else:
            cleaned.append(token)
            index += 1
    arguments: list[str] = []
    for name in ("--proxy", "--h-environment"):
        if name in extracted:
            arguments.extend((name, extracted[name]))
    return cleaned, arguments


def parse_workflow(tokens: list[str]) -> None:
    explicit_reset = False
    no_reset = False
    product: str | None = None
    recipient: str | None = None
    passthrough: list[str] = []
    index = 0
    while index < len(tokens):
        token = tokens[index]
        if token == "reset":
            explicit_reset = True
            index += 1
        elif token == "noreset":
            no_reset = True
            index += 1
        elif token in {"add", "checkout"}:
            if index + 1 >= len(tokens):
                fail(f"{token} requires an ID or -i")
            value = tokens[index + 1]
            if token == "add":
                if product is not None:
                    fail("add may appear only once")
                product = value
            else:
                if recipient is not None:
                    fail("checkout may appear only once")
                recipient = value
            index += 2
        elif token in {"--max-total", "--proxy", "--h-environment"}:
            if index + 1 >= len(tokens):
                fail(f"{token} requires a value")
            passthrough.extend((token, tokens[index + 1]))
            index += 2
        elif token in {"--verify-proxy", "--place-order", "--resume"}:
            passthrough.append(token)
            index += 1
        else:
            fail(f"unexpected workflow token {token!r}")

    if explicit_reset and no_reset:
        fail("reset and noreset are mutually exclusive")
    if product is None and recipient is None:
        if explicit_reset:
            run_script(
                "add_cached_to_cart.py",
                [*passthrough, "--reset-only", "--skip-add", "--skip-checkout"],
            )
        fail("cart requires reset, add, or checkout")
    if explicit_reset and product is None:
        fail("reset followed by checkout would empty the cart; add a product too")
    if "--place-order" in passthrough and recipient is None:
        fail("--place-order requires checkout <address-id|-i>")
    if product is not None and not any(
        (RUNTIME / "catalogs").glob("*-mcmaster-screws.json")
    ):
        fail("no cached catalog; run `./h402 catalog refresh` first")

    arguments = passthrough
    if product is None:
        arguments.extend(("--skip-add", "--no-reset"))
    else:
        arguments.extend(selector_argument(product, "--interactive-product", "--product"))
        if no_reset:
            arguments.append("--no-reset")
    if recipient is None:
        arguments.append("--skip-checkout")
    else:
        arguments.extend(
            selector_argument(recipient, "--interactive-recipient", "--recipient")
        )
    run_script("add_cached_to_cart.py", arguments)


def catalog_list() -> None:
    catalog_dir = RUNTIME / "catalogs"
    catalogs = sorted(catalog_dir.glob("*-mcmaster-screws.json"))
    if not catalogs:
        raise SystemExit(
            f"No catalogs found under {catalog_dir}. Run `./h402 catalog refresh`."
        )
    active = newest_catalog(catalog_dir)
    for path in reversed(catalogs):
        payload = json.loads(path.read_text(encoding="utf-8"))
        marker = "*" if path == active else " "
        count = len(payload.get("products", []))
        description = describe_catalog(path).replace("\nTimestamp: ", " — ")
        print(f"{marker} {description} — {count} products")
    print("\n* active catalog used by cart add")


def doctor(online: bool) -> None:
    required = [
        "HAI_API_KEY",
        "MCMASTER_EMAIL",
        "MCMASTER_PASSWORD",
        "CHECKOUT_CARD_NUMBER",
        "CHECKOUT_CARD_EXP_MONTH",
        "CHECKOUT_CARD_EXP_YEAR",
        "CHECKOUT_CARD_CVV",
    ]
    missing = [name for name in required if not os.environ.get(name)]
    checks = {
        "environment variables": not missing,
        "address book": (RUNTIME / "private/addresses.json").is_file(),
        "catalog": any((RUNTIME / "catalogs").glob("*-mcmaster-screws.json")),
        "profile state": (ROOT / "profile-state.json").is_file(),
    }
    if checks["address book"]:
        try:
            AddressBook.model_validate_json(
                (RUNTIME / "private/addresses.json").read_text(encoding="utf-8")
            )
        except Exception:
            checks["address book"] = False
    if online:
        reader = ImapCodeReader.from_env()
        try:
            if reader is None:
                raise RuntimeError("IMAP is not configured")
            reader.establish_baseline()
            checks["IMAP connection"] = True
        except Exception:
            checks["IMAP connection"] = False
    for label, ok in checks.items():
        print(f"{'OK' if ok else 'FAIL':4}  {label}")
    if missing:
        print(f"Missing variable names: {', '.join(missing)}")
    if not all(checks.values()):
        raise SystemExit(1)


def main() -> None:
    ensure_runtime_layout()
    tokens = sys.argv[1:]
    tokens, browser_options = extract_browser_options(tokens)
    if not tokens or tokens[0] in {"-h", "--help", "help"}:
        print(HELP)
        return
    resume_count = tokens.count("--resume")
    if resume_count > 1:
        fail("--resume may be specified only once")
    resume_requested = resume_count == 1
    if resume_requested:
        tokens = [token for token in tokens if token != "--resume"]
        if not tokens:
            fail("--resume must accompany a cart or checkout command")
    command, rest = tokens[0], tokens[1:]
    if command == "cart":
        rest.extend(browser_options)
        if resume_requested:
            rest.append("--resume")
        parse_workflow(rest)
        return
    elif command == "checkout":
        if not rest:
            fail("checkout requires one address ID or -i")
        rest.extend(browser_options)
        if resume_requested:
            rest.append("--resume")
        parse_workflow(["checkout", *rest])
        return
    elif command == "catalog":
        if rest == ["refresh"]:
            run_script("prepare_purchase.py", browser_options)
        elif rest == ["list"]:
            if browser_options:
                fail("browser options do not apply to catalog list")
            catalog_list()
        else:
            fail("catalog requires refresh or list")
    elif command == "profile":
        if browser_options:
            fail("browser options do not apply to profile management")
        if rest == ["open"]:
            run_script("h_profile.py", ["--open"])
        elif rest == ["publish"]:
            run_script("h_profile.py", [])
        else:
            fail("profile requires open or publish")
    elif command == "doctor":
        if browser_options:
            fail("browser options do not apply to doctor")
        if rest not in ([], ["--online"]):
            fail("doctor accepts only --online")
        doctor(rest == ["--online"])
    elif command == "logs":
        if browser_options:
            fail("browser options do not apply to logs")
        if rest not in ([], ["--local"]):
            fail("logs accepts only --local")
        log_path = RUNTIME / "logs/fetch-products.log"
        if rest == ["--local"]:
            command_line = f"tail -F {log_path!s} | grep --line-buffered LLOCALL"
            raise SystemExit(subprocess.run(["sh", "-c", command_line]).returncode)
        raise SystemExit(subprocess.run(["tail", "-F", str(log_path)]).returncode)
    else:
        fail(f"unknown command {command!r}")

    if resume_requested:
        fail("--resume is supported only for cart and checkout workflows")


if __name__ == "__main__":
    main()

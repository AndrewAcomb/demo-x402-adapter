watch_file pyproject.toml uv.lock

if [[ ! -d .venv ]]; then
  if command -v uv >/dev/null 2>&1; then
    uv venv .venv
  else
    log_error "uv is required to create .venv; install uv and run direnv reload"
  fi
fi

if [[ -d .venv ]]; then
  export VIRTUAL_ENV="$PWD/.venv"
  PATH_add .venv/bin
fi

if [[ -d bin ]]; then
  PATH_add bin
fi

if [[ -f .env ]]; then
  dotenv .env
fi
